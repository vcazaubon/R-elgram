# Réelgram — environment variables
# Copy to .env (dev/local). On Coolify, define these in the resource UI instead.
# .env is gitignored — never commit real secrets.

# --- Supabase (Project Settings -> API) --------------------------------------
SUPABASE_URL=https://xxxxxxxx.supabase.co        # Project URL
SUPABASE_ANON_KEY=eyJhbGciOi...                  # anon public key (frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...          # service_role key (backend, SECRET)
SUPABASE_JWT_SECRET=super-secret-jwt-...         # API -> JWT Secret (backend, verifies JWTs)

# --- Backend ------------------------------------------------------------------
MEDIA_TOKEN_SECRET=change-me-random-hex          # REQUIRED — openssl rand -hex 32
DATA_DIR=/data                                   # storage root (persisted volume)
MAX_VIDEO_MB=300                                 # max video size guard
# Instagram cookies (optional, fixes some private/age-gated Reels):
IG_COOKIES_FILE=/secrets/ig_cookies.txt          # path INSIDE the container (leave empty to disable)
IG_COOKIES_HOST_PATH=/dev/null                   # path on the host to mount (see README); /dev/null = disabled

# --- Frontend (runtime via env.js — public values only, no secrets) ----------
# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY, API_URL and ALLOW_SIGNUPS are injected
# verbatim into env.js at container start. Do NOT wrap them in double quotes and
# do NOT use backslashes — they are not escaped and would break env.js.
API_URL=/api                                     # same-origin API base (proxied by nginx)
ALLOW_SIGNUPS=true                               # show/hide the signup UI
