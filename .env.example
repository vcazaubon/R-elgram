# Réelgram — environment variables
# Copy to .env (dev/local). On Coolify, define these in the resource UI instead.
# .env is gitignored — never commit real secrets.
#
# IMPORTANT: put each value on its own line. Do NOT add an inline "# comment"
# after a value — it is NOT stripped and becomes part of the value (breaks the app).

# --- Supabase (Project Settings -> API) --------------------------------------

# Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Public key for the frontend.
# New projects: "sb_publishable_..." (API Keys page). Legacy: anon key "eyJ...".
SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-side full-access key for the backend (SECRET — bypasses RLS).
# New projects: a Secret key "sb_secret_..." (API Keys page). Legacy: service_role "eyJ...".
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# OPTIONAL — only for LEGACY projects that sign JWTs with HS256 (symmetric secret).
# New projects sign access tokens with asymmetric keys (ES256): the backend then
# verifies them via the project JWKS derived from SUPABASE_URL, so leave this empty.
SUPABASE_JWT_SECRET=

# --- Backend ------------------------------------------------------------------

# REQUIRED — signs media URLs (HMAC). Generate: openssl rand -hex 32
MEDIA_TOKEN_SECRET=change-me-random-hex

# storage root (persisted volume)
DATA_DIR=/data

# max video size guard (MB)
MAX_VIDEO_MB=300

# Instagram cookies (optional, fixes some private/age-gated Reels).
# path INSIDE the container (leave empty to disable)
IG_COOKIES_FILE=/secrets/ig_cookies.txt
# path on the host to mount (see README); /dev/null = disabled
IG_COOKIES_HOST_PATH=/dev/null

# --- Frontend (runtime via env.js — public values only, no secrets) ----------

# same-origin API base (proxied by nginx)
API_URL=/api

# show/hide the signup UI ("false" to lock signups)
ALLOW_SIGNUPS=true

# --- Public share shell -------------------------------------------------------

# URL publique de base pour construire les liens de partage (ex. https://reelgram.app)
PUBLIC_BASE_URL=
# Répertoire du frontend buildé (contient public-share.html) pour servir la coquille /s/<slug>
PUBLIC_DIST_DIR=
